---
import "../styles/global.css";
import BaseLayout from "../layouts/BaseLayout.astro";
import { personSchema } from "../utils/schema.ts";

// SEO metadata for home page
const pageTitle = "Home";
const metaDescription =
	"Welcome to DevFitra's website. I'm Rizki Fitra Rahman, a passionate Full Stack Developer specializing in modern web technologies like React, NextJS, and Laravel.";
const metaKeywords =
	"Fitra, web developer, full stack developer, react developer, nextjs, typescript, javascript, portfolio, Rizki Fitra Rahman";

// JSON-LD structured data for profile page
const profilePageSchema = {
	"@context": "https://schema.org",
	"@type": "ProfilePage",
	mainEntity: personSchema,
};
---

<style>
  .home__wrapper {
    display: flex;
    justify-content: center;
    height: calc(100vh - 62px);
  }

  .home__content {
    margin-top: 200px;
  }

  .home__title {
    color: #1a1a1a;
  }

  .home__content_footer {
    display: flex;
    justify-content: end;
  }
  .home__content_footer a {
    color: #b1b1b1;
    text-decoration: none;
  }
</style>

<BaseLayout
  pageTitle={pageTitle}
  metaDescription={metaDescription}
  metaKeywords={metaKeywords}
  schemaData={profilePageSchema}
>
  <div class="home__wrapper">
    <div class="home__content">
      <div>
        <h1 class="home__title text-gradient">Hello,</h1>
        <h1 class="home__title text-gradient">My name is Fitra</h1>
      </div>
      <div class="home__content_footer">
        <a href="/about" class="">About Me</a>
      </div>
    </div>
    
   
     <div
        style={{
          height: "100%",
          position: "absolute",
          top: "0",
          left: "0",
          right: "0",
          bottom: "0",
          zIndex: "-10",
          opacity: "0.02",
          backgroundImage: `
            linear-gradient(to right, #e2e8f0 1px, transparent 1px),
            linear-gradient(to bottom, #e2e8f0 1px, transparent 1px)
          `,
          backgroundSize: "20px 30px",
          WebkitMaskImage:
            "radial-gradient(ellipse 70% 60% at 50% 100%, #000 60%, transparent 100%)",
          maskImage:
            "radial-gradient(ellipse 70% 60% at 50% 100%, #000 60%, transparent 100%)",
        }}
      />
  </div>
</BaseLayout>
 